generator client {
  provider = "prisma-client-js"
  runtime  = "cloudflare" // Add this for Cloudflare Workers compatibility
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String
  posts    Post[]
}

model Post {
  id        String  @id @default(uuid())
  title     String
  content   String
  published Boolean @default(false)
  author    User    @relation(fields: [authorId], references: [id])
  authorId  String
}
